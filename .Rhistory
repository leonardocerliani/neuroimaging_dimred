df <- tibble(
start = 1:9,
end = start + 5,
sub = map(c("leo","cat","gabi"), ~ rep(.x,3)) %>% unlist(),
listnumba =list(seq(1:10))
)
library(dplyr)
library(purrr)
df <- tibble(
start = 1:9,
end = start + 5,
sub = map(c("leo","cat","gabi"), ~ rep(.x,3)) %>% unlist(),
listnumba =list(seq(1:10))
)
df
df %>%
mutate(duration = paste0(sub,end - start) )
# create a new col with a list resulting from
# a comparison of two cols
pf <- df %>%
rowwise() %>%
mutate(boh = list(listnumba == start) )
pf$boh
# do the same with a function
testnumba <- function(n1,n2, listnumba) {
ret <- ifelse(c(n1,n2) %in% listnumba, c(n1,n2), NA)
return(ret)
}
pf <- df %>%
rowwise() %>%
mutate(boh = list(testnumba(start,end,listnumba)) )
pf$listnumba
pf$boh
df
